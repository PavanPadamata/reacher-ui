generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Job {
  id          String   @id @default(cuid())
  name        String
  fileName    String
  totalEmails Int      @default(0)
  processed   Int      @default(0)
  safe        Int      @default(0)
  risky       Int      @default(0)
  invalid     Int      @default(0)
  unknown     Int      @default(0)
  unverifiable Int     @default(0)
  status      JobStatus @default(PENDING)
  concurrency Int      @default(10)
  groupId     String?  // links part1 + part2 of same original file
  partNumber  Int?     // 1 or 2
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  results     Result[]

  @@index([groupId])
}

model Result {
  id             String  @id @default(cuid())
  jobId          String
  email          String
  name           String  @default("")
  status         String  // safe | risky | invalid | unknown | unverifiable | error
  isReachable    String  @default("")
  isDisposable   Boolean @default(false)
  isRoleAccount  Boolean @default(false)
  isCatchAll     Boolean @default(false)
  mxAcceptsMail  Boolean @default(false)
  smtpDeliverable Boolean @default(false)
  smtpDisabled   Boolean @default(false)
  rawError       String?
  job            Job     @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, status])
  @@index([jobId])
}

enum JobStatus {
  PENDING
  RUNNING
  PAUSED
  COMPLETED
  STOPPED
  FAILED
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // bcrypt hashed
  createdAt DateTime @default(now())
}
